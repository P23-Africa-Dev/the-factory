{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ],
      "regex": "^/sw\\.js(?:/)?$"
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ],
      "regex": "^/manifest\\.json(?:/)?$"
    }
  ],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/crm/leads/[id]",
      "regex": "^/crm/leads/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/crm/leads/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/meetings/[id]",
      "regex": "^/meetings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/meetings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/meetings/[id]/edit",
      "regex": "^/meetings/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/meetings/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/reset-password/[token]",
      "regex": "^/reset\\-password/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/reset\\-password/(?<nxtPtoken>[^/]+?)(?:/)?$"
    },
    {
      "page": "/task/[id]",
      "regex": "^/task/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/task/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/task/[id]/complete",
      "regex": "^/task/([^/]+?)/complete(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/task/(?<nxtPid>[^/]+?)/complete(?:/)?$"
    },
    {
      "page": "/task/[id]/tracking",
      "regex": "^/task/([^/]+?)/tracking(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/task/(?<nxtPid>[^/]+?)/tracking(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/assistant",
      "regex": "^/assistant(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/assistant(?:/)?$"
    },
    {
      "page": "/crm",
      "regex": "^/crm(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/crm(?:/)?$"
    },
    {
      "page": "/crm/leads",
      "regex": "^/crm/leads(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/crm/leads(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/forgot-password",
      "regex": "^/forgot\\-password(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/forgot\\-password(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/map",
      "regex": "^/map(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/map(?:/)?$"
    },
    {
      "page": "/meetings",
      "regex": "^/meetings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/meetings(?:/)?$"
    },
    {
      "page": "/meetings/new",
      "regex": "^/meetings/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/meetings/new(?:/)?$"
    },
    {
      "page": "/offline",
      "regex": "^/offline(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/offline(?:/)?$"
    },
    {
      "page": "/profile",
      "regex": "^/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/profile(?:/)?$"
    },
    {
      "page": "/sync/conflicts",
      "regex": "^/sync/conflicts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sync/conflicts(?:/)?$"
    },
    {
      "page": "/sync/queue",
      "regex": "^/sync/queue(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sync/queue(?:/)?$"
    },
    {
      "page": "/tasks",
      "regex": "^/tasks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tasks(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}