# Copy to .env.local (or .env) — never commit real values.
# See also the workspace root .env.local.example for full documentation.

NEXT_PUBLIC_API_BASE_URL=https://api.thefactory23.com/api/v1
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
NEXT_PUBLIC_MAPBOX_ALLOWED_HOSTS=api.thefactory23.com,cdn.thefactory23.com
NEXT_PUBLIC_TRACKING_WS_URL=wss://api.thefactory23.com/tracking-ws
NEXT_PUBLIC_MAP_PROVIDER=mapbox
NEXT_PUBLIC_APP_ENV=production

# Mobile-only access: enforced on production hosts. On localhost in dev, browser access
# is allowed automatically so you can test the dashboard without installing the PWA.
# Set to false to also allow browser access on staging/production.
NEXT_PUBLIC_PWA_ONLY_MODE=false

# Canonical public URL for QR codes and install redirects (optional; inferred from host if unset).
# NEXT_PUBLIC_AGENT_PWA_URL=https://app.thefactory23.com
NEXT_PUBLIC_AGENT_PWA_URL=http://localhost:3001

# Absolute HTTPS URL for the Android APK (shown on /install when set).
# Google Drive share links work (normalized to direct download).
# NEXT_PUBLIC_AGENT_APK_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing
NEXT_PUBLIC_AGENT_APK_URL=

# Capacitor remote WebView target (used when building/syncing the Android shell).
# CAPACITOR_SERVER_URL=https://app.thefactory23.com
