# ─────────────────────────────────────────────────────────────────────────────
# Next.js environment variables — copy this file to .env.local and fill values
# .env.local is gitignored; never commit real credentials
# ─────────────────────────────────────────────────────────────────────────────

# ── Laravel API base URL ─────────────────────────────────────────────────────
# Include /api/v1, no trailing slash
# Local (via Docker nginx on port 8080):  http://localhost:8080/api/v1
# Production:                             https://api.thefactory23.com/api/v1
NEXT_PUBLIC_API_BASE_URL=https://api.thefactory23.com/api/v1

# ── Mapbox public token ───────────────────────────────────────────────────────
# Obtain from https://account.mapbox.com/ → Access tokens → Create a token
# Always use a PUBLIC token (starts with pk.) — never a secret token (sk.)
# In production, restrict this token to your domain(s) in the Mapbox dashboard
# (Account → Access tokens → Token → Allowed URLs)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
# Optional hardening: comma-separated hostnames allowed for map asset requests
# (in addition to *.mapbox.com and current window host).
# Example: NEXT_PUBLIC_MAPBOX_ALLOWED_HOSTS=api.thefactory23.com,cdn.thefactory23.com
NEXT_PUBLIC_MAPBOX_ALLOWED_HOSTS=api.thefactory23.com,cdn.thefactory23.com

# ── Google Maps optional provider ───────────────────────────────────────────
# Required when map provider is set to google.
# Restrict this browser key by referrer + API in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-only key for Google Places API (New) proxy — recommended for production.
# Enable "Places API (New)" in Google Cloud Console and restrict this key by IP.
# Falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY when unset (local dev only).
GOOGLE_PLACES_API_KEY=

# Optional: use OpenStreetMap Overpass when Google + Mapbox POI searches return empty.
# NEXT_PUBLIC_ENABLE_OVERPASS_POI_FALLBACK=true

# Runtime default provider before backend sync kicks in.
# Valid values: mapbox, google
NEXT_PUBLIC_MAP_PROVIDER=mapbox

# ── Real-time tracking WebSocket URL ─────────────────────────────────────────
# Connects to the Node.js relay server (backend/realtime-server)
# The relay must be reachable via this URL FROM THE BROWSER.
#
# Local (Docker + nginx proxy on port 8080):
NEXT_PUBLIC_TRACKING_WS_URL=wss://api.thefactory23.com/tracking-ws
#
# Production (must use wss:// for HTTPS sites):
# NEXT_PUBLIC_TRACKING_WS_URL=wss://api.thefactory23.com/tracking-ws
#
# NOTE: Always route through nginx — never connect directly to port 8081.
# The nginx config must have:
#   location /tracking-ws {
#     proxy_pass http://realtime:8081;
#     proxy_http_version 1.1;
#     proxy_set_header Upgrade $http_upgrade;
#     proxy_set_header Connection "upgrade";
#     proxy_set_header Host $host;
#   }

# ── Stripe publishable key (for in-dashboard card management) ─────────────────
# Use the same pk. value as STRIPE_KEY in the Laravel backend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── Avatar fallback (DigitalOcean Spaces direct origin) ───────────────────────
# Use the direct origin URL, not the .cdn. hostname, unless CDN is enabled.
NEXT_PUBLIC_SPACES_ORIGIN_URL=https://factory23-storage.lon1.digitaloceanspaces.com
NEXT_PUBLIC_AVATAR_DEFAULT_URL=https://factory23-storage.lon1.digitaloceanspaces.com/avatar/default/ghost.svg
