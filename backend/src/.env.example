MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

TASK_TRACKING_ARRIVAL_RADIUS_METERS=75
TASK_TRACKING_NEAR_RADIUS_METERS=250
TASK_TRACKING_NEAR_MAX_ACCURACY_METERS=150
TASK_TRACKING_ARRIVAL_MAX_ACCURACY_METERS=60
TASK_TRACKING_MIN_MOVEMENT_BEFORE_PROXIMITY_METERS=20
TASK_TRACKING_MIN_SECONDS_BETWEEN_NEAR_AND_ARRIVAL=10
TASK_TRACKING_PERSIST_MIN_INTERVAL_SECONDS=15
TASK_TRACKING_PERSIST_MIN_DISTANCE_METERS=20
TASK_TRACKING_MAX_BATCH_POINTS=50
TASK_TRACKING_REDIS_CHANNEL_PREFIX=factory23.tracking
TASK_TRACKING_RETENTION_DAYS=90
TASK_TRACKING_PRUNE_CHUNK_SIZE=1000

MAPBOX_PUBLIC_TOKEN=
MAPBOX_SECRET_TOKEN=
MAPBOX_DIRECTIONS_BASE_URL=https://api.mapbox.com
MAPBOX_DIRECTIONS_PROFILE=driving
MAPBOX_DIRECTIONS_GEOMETRIES=geojson
MAPBOX_DIRECTIONS_OVERVIEW=full
MAPBOX_DIRECTIONS_STEPS=false
MAPBOX_DIRECTIONS_ANNOTATIONS=distance,duration
MAPBOX_DIRECTIONS_MAX_COORDINATES=25
TRACKING_WS_PUBLIC_URL=ws://localhost:8081
TRACKING_API_PUBLIC_URL=http://localhost:8080/api/v1
MAP_PROVIDER_DEFAULT=mapbox

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Use an External OAuth consent screen in Google Cloud if you need non-workspace Gmail accounts.
# Single URI only — one value per environment. Do NOT use a comma-separated list.
# Local dev (Docker nginx on port 8080): http://localhost:8080/api/v1/calendar/integration/callback
# Production:                            https://api.thefactory23.com/api/v1/calendar/integration/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/api/v1/calendar/integration/callback
GOOGLE_CALENDAR_SCOPES=openid,email,profile,https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/calendar.events,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.modify
MEETING_DELETION_MODE=soft
MEETING_REMINDER_STALE_QUEUE_MINUTES=15

AI_STACK=openai_claude
AI_PROVIDER=openai
AI_FALLBACK_PROVIDER=claude
AI_DEFAULT_MODEL=auto
AI_EXEC_MODEL=auto
AI_ANALYST_MODEL=auto
AI_REQUEST_TIMEOUT_MS=30000
AI_STRICT_CONFIRMATION_BLOCKING=false
AI_STRICT_CONFIRMATION_BLOCKING_CODES=used_default_title,used_default_due_date
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=auto
OPENAI_AUDIO_MODEL=gpt-4o-mini-transcribe
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
CLAUDE_MODEL=auto
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_ROUTING_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NVIDIA_REQUEST_TIMEOUT_MS=120000
NVIDIA_OPERATIONAL_MAX_TOKENS=1000
NVIDIA_EXEC_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NVIDIA_ANALYST_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1

