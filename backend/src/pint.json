{
    "preset": "laravel",
    "rules": {
        "class_attributes_separation": {
            "elements": {
                "const": "one",
                "property": "one",
                "method": "one",
                "trait_import": "none",
                "case": "none"
            }
        },
        "not_operator_with_successor_space": true,
        "binary_operator_spaces": {
            "default": "single_space"
        },
        "concat_space": {
            "spacing": "none"
        }
    }
}
