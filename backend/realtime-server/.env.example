# ─────────────────────────────────────────────────────────────────────────────
# realtime-server environment variables
# Copy to .env (or inject via docker-compose / container runtime)
# docker-compose.yml already sets all of these with safe defaults.
# Only override here when running the relay standalone (outside Docker).
# ─────────────────────────────────────────────────────────────────────────────

# ── WebSocket server binding ──────────────────────────────────────────────────
TRACKING_WS_HOST=0.0.0.0
TRACKING_WS_PORT=8081

# ── Redis connection ──────────────────────────────────────────────────────────
# Use TRACKING_WS_REDIS_URL for full URL (e.g. redis://:password@host:6379/0)
# OR use the individual fields below. URL takes priority if both are set.
TRACKING_WS_REDIS_URL=
TRACKING_WS_REDIS_HOST=127.0.0.1
TRACKING_WS_REDIS_PORT=6379
TRACKING_WS_REDIS_PASSWORD=
TRACKING_WS_REDIS_DB=0

# ── Redis channel prefix ──────────────────────────────────────────────────────
# MUST match TASK_TRACKING_REDIS_CHANNEL_PREFIX in the Laravel .env
# Default: factory23.tracking
TASK_TRACKING_REDIS_CHANNEL_PREFIX=factory23.tracking

# ── Auth (token introspection) ────────────────────────────────────────────────
# The relay validates bearer tokens by calling /api/v1/user/me on this base URL.
# In Docker this is http://nginx (internal service name).
# Standalone (outside Docker): point to your Laravel API URL.
TRACKING_WS_AUTH_API_BASE_URL=http://localhost:8080
TRACKING_WS_AUTH_ME_PATH=/api/v1/user/me

# ── Timeouts and limits ───────────────────────────────────────────────────────
TRACKING_WS_AUTH_TIMEOUT_MS=10000
TRACKING_WS_HEARTBEAT_MS=30000
TRACKING_WS_MAX_MESSAGE_BYTES=32768

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
TRACKING_WS_LOG_LEVEL=info

# ── Development only — NEVER enable in production ────────────────────────────
# Skip token auth entirely (any connection is accepted as admin).
# Only useful for local testing without a running Laravel API.
TRACKING_WS_ALLOW_INSECURE_SKIP_AUTH=false
