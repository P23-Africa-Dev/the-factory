APP_NAME="Factory API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=factory_api
DB_USERNAME=factory_user
DB_PASSWORD=factory_password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

TASK_TRACKING_ARRIVAL_RADIUS_METERS=75
TASK_TRACKING_NEAR_RADIUS_METERS=250
TASK_TRACKING_NEAR_MAX_ACCURACY_METERS=150
TASK_TRACKING_ARRIVAL_MAX_ACCURACY_METERS=60
TASK_TRACKING_MIN_MOVEMENT_BEFORE_PROXIMITY_METERS=20
TASK_TRACKING_MIN_SECONDS_BETWEEN_NEAR_AND_ARRIVAL=10
TASK_TRACKING_PERSIST_MIN_INTERVAL_SECONDS=15
TASK_TRACKING_PERSIST_MIN_DISTANCE_METERS=20
TASK_TRACKING_MAX_BATCH_POINTS=50
TASK_TRACKING_REDIS_CHANNEL_PREFIX=factory23.tracking
TASK_TRACKING_RETENTION_DAYS=90
TASK_TRACKING_PRUNE_CHUNK_SIZE=1000
MAP_PROVIDER_DEFAULT=mapbox

AI_PROVIDER=openai
AI_FALLBACK_PROVIDER=claude
AI_DEFAULT_MODEL=auto
AI_EXEC_MODEL=auto
AI_ANALYST_MODEL=auto
AI_REQUEST_TIMEOUT_MS=30000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=auto
OPENAI_AUDIO_MODEL=gpt-4o-mini-transcribe
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
CLAUDE_MODEL=auto

FRONTEND_URL=http://localhost:3000
ENTERPRISE_ONBOARDING_SETUP_PATH=/enterprise/setup
ENTERPRISE_ONBOARDING_SETUP_URL=
