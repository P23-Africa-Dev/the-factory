# Normalize all text files to LF on commit (prevents CRLF creeping in from Windows editors)
* text=auto eol=lf

# Explicitly enforce LF for PHP/config/web files
*.php    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.env*   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.xml    text eol=lf
*.lock   text eol=lf

# Binary files — never touch line endings
*.png    binary
*.jpg    binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
